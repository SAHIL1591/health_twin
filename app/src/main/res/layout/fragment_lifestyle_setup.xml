<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context="LifeStyleSetupFragment"
    android:background="@drawable/bg_splash_gradient">

    <!-- ================= Scroll Content ================= -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnGenerate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/lfBack"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_back"
                    app:tint="#9BB0C8"/>

                <!-- ===== HEADER ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lifestyle"
                    android:paddingStart="14dp"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"/>

            </LinearLayout>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Adjust these habits to model your biological future."
                android:textSize="15sp"
                android:textColor="#9BB0C8"
                android:layout_marginTop="8dp"/>

            <Space
                android:layout_width="match_parent"
                android:layout_height="32dp"/>

            <!-- ================= SMOKING CARD ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSmoking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1F3B5C"
                app:cardBackgroundColor="#0F1E36"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Top Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Smoking"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:paddingStart="12dp"
                            android:paddingTop="8dp"
                            android:textColor="@android:color/white"/>

                        <TextView
                            android:id="@+id/tvSmokingValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:paddingEnd="12dp"
                            android:paddingTop="8dp"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#00D4FF"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How much do you smoke?"
                        android:textSize="14sp"
                        android:paddingStart="12dp"
                        android:textColor="#9BB0C8"
                        android:layout_marginTop="4dp"/>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderSmoking"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="10"
                        android:stepSize="1"
                        android:value="0"
                        android:layout_marginTop="16dp"
                        app:trackColorActive="#00D4FF"
                        app:trackColorInactive="@color/white"
                        app:thumbTint="#00D4FF" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space android:layout_width="match_parent" android:layout_height="24dp"/>

            <!-- ================= ALCOHOL CARD ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAlcohol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1F3B5C"
                app:cardBackgroundColor="#0F1E36"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Alcohol"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:paddingStart="12dp"
                            android:paddingTop="8dp"
                            android:textColor="@android:color/white"/>

                        <TextView
                            android:id="@+id/tvAlcoholValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="18sp"
                            android:paddingEnd="12dp"
                            android:paddingTop="8dp"
                            android:textStyle="bold"
                            android:textColor="#00D4FF"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weekly alcohol consumption"
                        android:textSize="14sp"
                        android:paddingStart="12dp"
                        android:textColor="#9BB0C8"
                        android:layout_marginTop="4dp"/>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderAlcohol"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="10"
                        android:stepSize="1"
                        android:value="0"
                        android:layout_marginTop="16dp"
                        app:trackColorActive="#00D4FF"
                        app:trackColorInactive="@color/white"
                        app:thumbTint="#00D4FF" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <Space android:layout_width="match_parent" android:layout_height="24dp"/>

            <!-- ================= EXERCISE CARD ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardExercise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1F3B5C"
                app:cardBackgroundColor="#0F1E36"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Exercise"
                            android:textSize="18sp"
                            android:paddingStart="12dp"
                            android:paddingTop="8dp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"/>

                        <TextView
                            android:id="@+id/tvExerciseValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="18sp"
                            android:paddingEnd="12dp"
                            android:paddingTop="8dp"
                            android:textStyle="bold"
                            android:textColor="#00D4FF"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Physical activity level"
                        android:textSize="14sp"
                        android:textColor="#9BB0C8"
                        android:paddingStart="12dp"
                        android:layout_marginTop="4dp"/>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderExercise"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="10"
                        android:stepSize="1"
                        android:value="0"
                        android:layout_marginTop="16dp"
                        app:trackColorActive="#00D4FF"
                        app:trackColorInactive="@color/white"
                        app:thumbTint="#00D4FF"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space android:layout_width="match_parent" android:layout_height="24dp"/>

            <!-- ================= SLEEP CARD ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSleep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1F3B5C"
                app:cardBackgroundColor="#0F1E36"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Sleep"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:paddingStart="12dp"
                            android:paddingTop="8dp"
                            android:textColor="@android:color/white"/>

                        <TextView
                            android:id="@+id/tvSleepValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7h"
                            android:textSize="18sp"
                            android:paddingEnd="12dp"
                            android:paddingTop="8dp"
                            android:textStyle="bold"
                            android:textColor="#00E676"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Average hours per night"
                        android:textSize="14sp"
                        android:textColor="#9BB0C8"
                        android:paddingStart="12dp"
                        android:layout_marginTop="4dp"/>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderSleep"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="10"
                        android:stepSize="1"
                        android:value="0"
                        android:layout_marginTop="16dp"
                        app:trackColorActive="#00D4FF"
                        app:trackColorInactive="@color/white"
                        app:thumbTint="#00D4FF"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- ================= CTA ================= -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGenerate"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="See Your Digital Twin"
        android:textSize="18sp"
        android:textAllCaps="false"
        android:layout_margin="24dp"
        app:cornerRadius="32dp"
        style="@style/PrimaryButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>